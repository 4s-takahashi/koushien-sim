# ─────────────────────────────────────────────────────────────
# koushien-sim 環境変数テンプレート
#
# このファイルをコピーして .env を作成し、実際の値を設定してください。
#   cp .env.example .env
# .env は .gitignore で除外されているため、リポジトリにはコミットしません。
# ─────────────────────────────────────────────────────────────

# MySQL 接続 URL（Prisma 用）
# 書式: mysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="mysql://koushien:YOUR_PASSWORD@localhost:3306/koushien_sim"

# ─────────────────────────────────────────────────────────────
# 以下は v0.24.0 以前の Redis/Vercel KV 設定（現在は不使用）
# ─────────────────────────────────────────────────────────────
# REDIS_URL="redis://localhost:6379"
# KV_REST_API_URL="https://..."
# KV_REST_API_TOKEN="..."
